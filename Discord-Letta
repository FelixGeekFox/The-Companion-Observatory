GROUP_CHANNEL_COOLDOWN_SECONDS=45
USER_COOLDOWN_SECONDS=20

# Response length
MAX_PUBLIC_RESPONSE_CHARS=800
MAX_PRIVATE_FELIX_RESPONSE_CHARS=3000

# Autonomous owner check-ins
AUTONOMOUS_CHECKINS=true
CHECKIN_MIN_PER_DAY=1
CHECKIN_MAX_PER_DAY=3
